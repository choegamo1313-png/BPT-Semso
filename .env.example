# Copy this file to .env and fill in real values before running the server.
# Never commit the real .env file to GitHub.

# Random long string used to sign login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string

# Password for the default admin account created on first run.
# Change this immediately after your first login via Administrator > Login Settings.
ADMIN_DEFAULT_PASSWORD=admin123

# Port the API server listens on. Render sets this automatically in production.
PORT=4000

# Comma-separated list of allowed frontend origins (your Render static site URL,
# plus http://localhost for local testing). No trailing slashes.
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:5500
